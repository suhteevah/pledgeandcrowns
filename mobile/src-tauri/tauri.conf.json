{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pledge and Crown",
  "version": "0.1.0",
  "identifier": "com.pledgeandcrown.game",
  "build": {
    "frontendDist": "../../web"
  },
  "app": {
    "windows": [
      {
        "title": "Pledge & Crown",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
